
// Классы сущностей в системе

class Human 

class Pet {
    rel owner(Human) : {* -> 1};
}

class Dog : Pet {
    obj prop kind: boolean; // Хороший ли характер
}

class Cat : Pet 



// Люди в системе

obj Alice : Human
obj Peter : Human

// Коты в системе

obj Basya : Cat {
    owner(Peter);
}

obj Tuzik : Cat {
    owner(Alice);
}


// Собаки в системе

obj Sharik: Dog {
    owner(Peter);
    kind = true;
}

obj Ostin: Dog {
    owner(Alice);
    kind = false;
}